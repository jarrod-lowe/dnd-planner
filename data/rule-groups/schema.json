{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://dnd-planner.local/rule-groups",
  "title": "D&D Planner Rule Groups",
  "description": "Schema for D&D Planner rule group YAML files",
  "type": "object",
  "required": ["ruleGroups"],
  "properties": {
    "ruleGroups": {
      "type": "array",
      "description": "Array of rule groups to sync to DynamoDB",
      "items": {
        "$ref": "#/definitions/ruleGroup"
      }
    }
  },
  "definitions": {
    "ruleGroup": {
      "type": "object",
      "required": ["id"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this rule group",
          "examples": ["paladin-level1-divine-sense", "fighter-champion-improved-critical"]
        },
        "name": {
          "type": "string",
          "description": "i18n key for display name",
          "examples": ["ruleGroups.paladin.divineSense.name"]
        },
        "description": {
          "type": "string",
          "description": "i18n key for description",
          "examples": ["ruleGroups.paladin.divineSense.description"]
        },
        "rules": {
          "type": "array",
          "description": "Array of rules in this rule group",
          "items": {
            "$ref": "#/definitions/rule"
          }
        }
      },
      "additionalProperties": false
    },
    "rule": {
      "type": "object",
      "required": ["id", "activities"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this rule"
        },
        "description": {
          "type": "string",
          "description": "i18n key for rule description"
        },
        "ui": {
          "type": "object",
          "description": "UI-specific configuration",
          "additionalProperties": true
        },
        "vars": {
          "type": "object",
          "description": "Rule variables with default values",
          "additionalProperties": {
            "$ref": "#/definitions/varDefinition"
          }
        },
        "selections": {
          "type": "object",
          "description": "User-selected values for vars",
          "additionalProperties": true
        },
        "phase": {
          "$ref": "#/definitions/phase",
          "default": "normal"
        },
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "when": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/condition"
          },
          "description": "Conditions that must be satisfied for rule execution"
        },
        "after": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/groupReference"
          },
          "description": "Group dependencies that must settle first"
        },
        "group": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Groups this rule belongs to"
        },
        "activities": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/activity"
          },
          "description": "Activities to execute when rule runs"
        }
      },
      "additionalProperties": false
    },
    "phase": {
      "type": "string",
      "enum": ["early", "normal", "safeguard"],
      "description": "Execution phase"
    },
    "groupReference": {
      "type": "object",
      "required": ["group"],
      "properties": {
        "group": {
          "type": "string",
          "description": "Group name to depend on"
        }
      },
      "additionalProperties": false
    },
    "varDefinition": {
      "type": "object",
      "required": ["default"],
      "properties": {
        "default": {
          "$ref": "#/definitions/source",
          "description": "Default value source"
        },
        "capture": {
          "type": "boolean",
          "description": "When true, capture fact value as selection when added to plan",
          "default": false
        }
      },
      "additionalProperties": false
    },
    "target": {
      "type": "object",
      "description": "Target for activity operations - exactly one of fact or var must be present",
      "minProperties": 1,
      "maxProperties": 1,
      "properties": {
        "fact": {
          "type": "string",
          "description": "Fact path to target"
        },
        "var": {
          "type": "string",
          "description": "Variable name to target"
        }
      },
      "additionalProperties": false
    },
    "source": {
      "type": "object",
      "description": "Value source - exactly one of number, fact, var, or condition must be present",
      "minProperties": 1,
      "maxProperties": 1,
      "properties": {
        "number": {
          "type": "number",
          "description": "Literal numeric value"
        },
        "fact": {
          "type": "string",
          "description": "Reference to a fact in working state"
        },
        "var": {
          "type": "string",
          "description": "Reference to a rule variable"
        },
        "condition": {
          "$ref": "#/definitions/condition",
          "description": "Condition to evaluate, returns 1 if true, 0 if false"
        }
      },
      "additionalProperties": false
    },
    "condition": {
      "type": "object",
      "description": "Condition for when/legalWhen clauses",
      "oneOf": [
        {
          "required": ["fact"],
          "properties": {
            "fact": {
              "type": "string",
              "description": "Fact path to check"
            },
            "operator": {
              "$ref": "#/definitions/comparisonOperator"
            },
            "value": {
              "type": "number",
              "description": "Value to compare against (required when operator is present)"
            }
          }
        },
        {
          "required": ["event"],
          "properties": {
            "event": {
              "type": "string",
              "description": "Event name to check"
            }
          }
        }
      ]
    },
    "comparisonOperator": {
      "type": "string",
      "enum": [
        "equals",
        "notEquals",
        "greaterThan",
        "greaterThanOrEqual",
        "lessThan",
        "lessThanOrEqual"
      ],
      "description": "Comparison operator for fact conditions"
    },
    "activity": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for this activity"
        },
        "type": {
          "type": "string",
          "enum": [
            "numberSet",
            "numberIncrement",
            "numberCopy",
            "numberSum",
            "numberFunction",
            "emitEvent",
            "generateRule",
            "offerRule"
          ],
          "description": "Activity type"
        },
        "target": {
          "$ref": "#/definitions/target",
          "description": "Target for the activity (for numberSet, numberIncrement, numberCopy, numberSum, numberFunction)"
        },
        "source": {
          "$ref": "#/definitions/source",
          "description": "Source value reference (for numberSet, numberIncrement, numberCopy)"
        },
        "sources": {
          "type": "array",
          "items": { "$ref": "#/definitions/source" },
          "description": "Array of source value references (for numberSum, numberFunction)"
        },
        "max": {
          "type": "string",
          "description": "Maximum value fact path (for numberIncrement)"
        },
        "subtract": {
          "type": "boolean",
          "description": "For numberIncrement: subtract the value instead of adding",
          "default": false
        },
        "function": {
          "type": "string",
          "enum": ["statToModifier", "multiply"],
          "description": "Named function (for numberFunction)"
        },
        "args": {
          "type": "object",
          "description": "Additional arguments for the function (for numberFunction)",
          "additionalProperties": true
        },
        "event": {
          "type": "string",
          "description": "Event name (for emitEvent)"
        },
        "rule": {
          "$ref": "#/definitions/rule",
          "description": "Rule to generate or offer"
        },
        "legalWhen": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/illegalWhenEntry"
          },
          "description": "Conditions for rule legality (for offerRule)"
        }
      },
      "additionalProperties": false
    },
    "illegalWhenEntry": {
      "type": "object",
      "required": ["condition"],
      "properties": {
        "condition": {
          "$ref": "#/definitions/condition"
        },
        "illegalDiagnostics": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/diagnostic"
          }
        }
      }
    },
    "diagnostic": {
      "type": "object",
      "required": ["code", "severity"],
      "properties": {
        "code": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["error", "warning", "notice"]
        }
      }
    }
  }
}
